<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "mantoujun12's Website" }}</title>
    <!-- 使用绝对路径，部署后从站点根目录解析 -->
    <link rel="stylesheet" href="/style/style.css">
    <link rel="stylesheet" href="/style/prism-theme.css">
    <link href="https://fontsapi.zeoseven.com/161/main/result.css" onload="this.rel='stylesheet'" rel="preload"
        as="style" crossorigin />
