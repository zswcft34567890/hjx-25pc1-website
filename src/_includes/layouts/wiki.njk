---
layout: layouts/main
---

<button class="wiki-sidebar-toggle" type="button" aria-label="切换侧边栏" aria-expanded="true">
    <span class="wiki-sidebar-toggle-icon"></span>
</button>

<div class="wiki-layout">
    <aside class="wiki-sidebar">
        <h3 class="wiki-sidebar-title">📚 Wiki</h3>
        <nav class="wiki-nav">
            <ul>
                <li><a href="{{ '/wiki.html' | url }}" class="wiki-nav-home">📖 全部</a></li>
            </ul>

            {#- 独立导航：基于 collections.wikiByCategory，不依赖 eleventyNavigation -#}
            {%- for group in collections.wikiByCategory %}
            <div class="wiki-nav-group" data-category="{{ group.name }}">
                <h4 class="wiki-nav-group-title">{{ group.label }}</h4>
                <ul class="wiki-nav-group-list">
                    {%- for entry in group.pages %}
                    <li>
                        <a href="{{ entry.url | url }}" {%- if entry.url==page.url %} class="active" {% endif %}>
                            {{ entry.data.title }}
                        </a>
                    </li>
                    {%- endfor %}
                </ul>
            </div>
            {%- endfor %}
        </nav>
    </aside>
    <main class="wiki-content">
        <article class="wiki-article">
            {%- if description %}
            <p class="wiki-description">{{ description }}</p>
            {%- endif %}
            {{ content | safe }}
            <hr>
            <p class="wiki-edit-link">
                <a href="https://github.com/hjx-25pc1/hjx-25pc1.github.io/edit/main/src/wiki/{{ page.fileSlug }}.md"
                    target="_blank" rel="noopener">
                    ✏️ 在 GitHub 上编辑此页
                </a>
            </p>
        </article>
    </main>
</div>

<script src="{{ '/js/wiki-sidebar.js' | url }}"></script>