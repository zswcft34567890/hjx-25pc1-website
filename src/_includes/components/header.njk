<header>
    <input type="checkbox" id="nav-toggle" hidden>
    <div class="nav-title"><a href="/"><i class="fa-solid fa-school"></i></a></div>
    <label for="nav-toggle" class="nav-hamburger"><i class="fa-solid fa-bars"></i></label>
    <nav>
        <button type="button" class="nav-drawer-close" aria-label="关闭导航菜单"><i class="fa-solid fa-xmark"></i></button>
        <div class="nav-btns">
            <a href="/"><i class="fa-solid fa-house"></i><span class="hover-show">首页</span></a>
            <a href="/article.html"><i class="fa-solid fa-book"></i><span class="hover-show">文章</span></a>
            <a href="/wiki.html"><i class="fa-solid fa-book-open"></i><span class="hover-show">Wiki</span></a>
            <a href="/zone.html"><i class="fa-solid fa-arrow-pointer"></i><span class="hover-show">分区</span></a>
            <a href="https://github.com/hjx-25pc1/hjx-25pc1.github.io"><i class="fa-brands fa-github"></i><span
                    class="hover-show">此 Github 项目</span></a>
            <a href="#" class="nav-popup-btn" aria-haspopup="true" aria-expanded="false" aria-controls="nav-popup"
