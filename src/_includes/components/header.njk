    <label for="nav-toggle" class="nav-hamburger"><i class="fa-solid fa-bars"></i></label>
    <nav>
        <button type="button" class="nav-drawer-close" aria-label="关闭导航菜单"><i class="fa-solid fa-xmark"></i></button>
        <div class="nav-btns">
            <a href="/" title="首页"><i class="fa-solid fa-house"></i><span class="mobile-only">首页</span></a>
            <a href="/article.html"><i class="fa-solid fa-book" title="文章"></i><span class="mobile-only">文章</span></a>
            <a href="/wiki.html"><i class="fa-solid fa-book-open" title="Wiki"></i><span
                    class="mobile-only">Wiki</span></a>
            <a href="/zone.html" title="分区"><i class="fa-solid fa-arrow-pointer"></i><span
