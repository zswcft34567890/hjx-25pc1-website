{# ============================================================
贡献者头像墙组件
------------------------------------------------------------
数据源：src/assets/img/contributors.json（由 GitHub Action 定期生成）
渲染方式：由 src/js/contributors.js 拉取后动态挂载到 #contributors-grid
若 JS 未加载/数据缺失，回退为静态链接列表（保证可访问）

用法：
{% include "components/contributors.njk" %}
============================================================ #}
<div class="contributors-wall" id="contributors-wall">
    <div class="contributors-grid" id="contributors-grid" data-src="{{ '/assets/img/contributors.json' | url }}"
        aria-label="贡献者">
        <p class="contributors-loading">贡献者加载中…</p>
    </div>
    <p class="contributors-credit">
        <small>由 <a href="https://github.com/{{ github.repository or 'hjx-25pc1/hjx-25pc1.github.io' }}" target="_blank"
                rel="noopener noreferrer">GitHub API</a> 自动生成</small>
    </p>
</div>